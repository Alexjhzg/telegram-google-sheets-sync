# ──────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ──────────────────────────────────────────────────────────────

# Token del bot obtenido desde @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklMNOpqrsTUVwxyz

# ID de la hoja de cálculo de Google Sheets
# (es la parte larga de la URL entre /d/ y /edit)
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Email de la cuenta de servicio de Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=mi-cuenta@mi-proyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio (incluir las cabeceras BEGIN/END)
# En el archivo .env real, reemplaza los saltos de línea reales por \n
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"
